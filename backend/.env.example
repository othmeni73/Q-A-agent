# ──────────────────────────────────────────────────────────────
# backend/.env.example
#
# Copy to `backend/.env` and fill in the secrets. `.env` is
# gitignored; this file is not. Non-secret config lives in
# backend/config.yaml (committed).
#
# The full stack runs at zero cost on free tiers — no credit
# card required on any of the two providers below.
# ──────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000


# ── LLM gateway (cloud chat + rewriter) ──────────────────────
# OpenRouter — single API key, routes to multiple upstream providers.
# Used by:
#   - chat model        (nvidia/nemotron-3-super-120b-a12b:free, benchmark-ranked #1)
#   - query rewriter    (google/gemma-3-4b-it:free)
#   - benchmark script  (all candidate models)
# Free tier, no card: https://openrouter.ai/keys
OPENROUTER_API_KEY=


# ── Google AI Studio (embeddings + contextual prefix) ────────
# Direct Google API, not via OpenRouter — needed for:
#   - embeddings             (text-embedding-004, 768-dim)
#   - contextual-prefix LLM  (gemini-2.5-flash, with native context caching)
# Free tier: 1500 RPD, 1M tokens/day, no card:
#   https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=


# ── Vector DB ────────────────────────────────────────────────
# Qdrant runs locally via Docker; no cloud credentials needed.
# Only set if pointing at a non-default Qdrant:
# QDRANT_URL=http://localhost:6333


# ── Judges + reranker (no env needed) ────────────────────────
# Judges (pairwise relevance + pointwise groundedness) run on
# local Ollama (gemma2:27b). See README "Technology choices".
# Reranker (BGE v2-m3) runs in-process via @xenova/transformers.
# Neither requires any environment variable.
